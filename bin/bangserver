#!/bin/sh
#
# $Id$
#
# Command line launcher for the Bang! development server

BANG_HOME=`dirname $0`/..
BANG_HOME=`cd $BANG_HOME ; pwd`
HOSTNAME=`hostname`
JARGS=""
NODE="frontier_town"

SERVER_MEMORY=384M
if [ -f $BANG_HOME/etc/test/server.conf ]; then
    . $BANG_HOME/etc/test/server.conf
else
    echo "Missing $BANG_HOME/etc/test/server.conf; can't run server."
    exit 255
fi

# parse our arguments
while [ ! -z "$1" ]; do
    case "$1" in
        -D*)
            JARGS="$JARGS $1"
            ;;

        *)
            NODE="$1"
            ;;
    esac
    shift
done

# build our classpath from the output of './gradlew deploy'
if [ ! -d $BANG_HOME/build/server ]; then
    echo "Missing $BANG_HOME/build/server; run './gradlew deploy' first."
    exit 255
fi
CLASSPATH=$BANG_HOME/assets/build/staging
for JAR in $BANG_HOME/build/server/*.jar; do
    CLASSPATH=$CLASSPATH:$JAR
done
export CLASSPATH

CLASS=com.threerings.bang.server.BangServer
exec java -server -Xmx$SERVER_MEMORY \
  -Djava.awt.headless=true \
  -Dbang.home=$BANG_HOME \
  -Dresource_dir=$BANG_HOME/assets/build/staging/rsrc \
  -Drsrc_cache_dir=/tmp \
  -Dno_unpack_resources=true \
  -Dhostname=$HOSTNAME -Dnode=$NODE -Dis_node=true $JARGS $CLASS
